<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.idz.trailsync.ProfileFragment"
        android:label="Personal Info"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/chatbotFragment"
        android:name="com.idz.trailsync.ChatbotFragment"
        android:label="Chatbot" />

    <fragment
        android:id="@+id/createPostFragment"
        android:name="com.idz.trailsync.features.createPost.CreatePostFragment"
        android:label="Upsert post">
        <argument
            android:name="postId"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.idz.trailsync.features.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_postDetailsFragment"
            app:destination="@+id/postDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/savedPostsFragment"
        android:name="com.idz.trailsync.SavedPostsFragment"
        android:label="Saved Posts"
        tools:layout="@layout/fragment_saved_posts" />

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.idz.trailsync.features.profile.EditProfileFragment"
        android:label="Edit Profile"
        tools:layout="@layout/fragment_edit_profile" />

    <fragment
        android:id="@+id/postDetailsFragment"
        android:name="com.idz.trailsync.features.post.PostDetailsFragment"
        android:label="Post Details"
        tools:layout="@layout/fragment_post_details">
        <argument
            android:name="post"
            app:argType="com.idz.trailsync.model.Post" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.idz.trailsync.features.Register.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register" />

</navigation>